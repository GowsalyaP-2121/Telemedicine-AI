    {
      "parameters": {
        "jsCode": "// Extract input from the webhook payload\nconst body = $input.first().json.body ?? {};\nconst name = body.name ?? \"\";\nconst email = body.email ?? \"\";\nconst language = body.language ?? \"English\";\nconst symptoms = body.symptoms ?? \"\";\n\nconst languageMap = {\n  Tamil: \"ta\",\n  Hindi: \"hi\",\n  Telugu: \"te\",\n  Malayalam: \"ml\",\n  Kannada: \"kn\",\n  Marathi: \"mr\",\n  Bengali: \"bn\",\n  Gujarati: \"gu\",\n  English: \"en\",\n};\n\nconst lang_code = languageMap[language] || \"en\";\n\nreturn [\n  {\n    json: {\n      name,\n      email,\n      lang_code,\n      symptoms,\n    },\n  },\n];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -480,
        -120
      ],
      "id": "24015ab7-e27d-4eb4-aeea-d2576a58c045",
      "name": "Code"
    },
    {
      "parameters": {
        "promptType": "define",
        "text": "=You are a medical language translator. Translate the following patient symptom into English. Do not add or modify meaning.\n\nLanguage Code: {{ $json.lang_code }}\nText: {{ $('Webhook').item.json.body.symptoms }}\n\nReturn only the English translation.",
        "options": {}
      },
      "type": "@n8n/n8n-nodes-langchain.agent",
